# App env. Copy to .env and fill. Never commit the real .env.

# ---------- Database ----------
# We connect to an EXISTING Postgres on the VM (managed by a separate
# docker-compose). The `borderless` database is created once via
# scripts/vm-init-borderless.sql.
#
# IMPORTANT: if the password contains special characters, URL-encode them.
#   '@' -> '%40'   ':' -> '%3A'   '/' -> '%2F'   '#' -> '%23'
# Example: password 'X3dres_ecHA@' becomes 'X3dres_ecHA%40' below.
DATABASE_URL=postgresql+asyncpg://radar:<URL_ENCODED_PASSWORD>@<VM_HOST>:5433/borderless

# ---------- Slack ----------
# Ops receive 20/80/7-day alerts here.
SLACK_WEBHOOK_URL=

# ---------- Gemini LLM ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ---------- Inbound API auth ----------
# Clients send: Authorization: <API_AUTH_KEY>  (bare token, no Bearer)
API_AUTH_KEY=

# ---------- Self-reference ----------
API_URL=http://localhost:8000

# ---------- External callback (optional) ----------
# We POST 20/80/7-day checkpoint payloads here. Leave blank to skip.
EXTERNAL_CALLBACK_URL=
EXTERNAL_CALLBACK_KEY=

# ---------- 7-day timeout sweep ----------
SEVEN_DAY_JOB_ENABLED=true
SEVEN_DAY_JOB_INTERVAL_MINUTES=60
